{
    "chmod": "0755",
    "compactors": [
        "KevinGH\\Box\\Compactor\\Php",
        "KevinGH\\Box\\Compactor\\Json"
    ],
    "compression": "GZ",
    "main": "vendor/autoload.php",
    "output": "freshtracker.phar",
    "force-autodiscovery": true,

    "stub": false,

    "check-requirements": false,

    "finder": [
        {
            "name": "*.php",
            "in": ["app"]
        },
        {
            "name": "*.yml",
            "in": ["."]
        },
        {
            "name": "*.css",
            "in": ["public/assets"]
        },
        {
            "name": "*.js",
            "in": ["public/assets"]
        },
        {
            "name": ["*.php", "*.json", "*.h", "*.so", "*.dll"],
            "in": "vendor",
            "exclude": [
                ".github",
                ".editorconfig",
                "infection.json.dist",
                ".php-cs-fixer.dist.php",
                ".valgrindc",
                "*.exe",
                "*.md",
                "LICENSE",
                "psalm.xml",
                "test",
                "tests",
                "Tests",
                "examples",
                ".gitignore",
                ".hhconfig",
                ".travis*",
                "phpunit*",
                "docs",
                "doc"
            ]
        }
    ],
    "files": ["public/_version"],
    "dump-autoload": true
}